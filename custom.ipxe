#!ipxe
###
### netboot.xyz-custom menu
###

:custom
clear custom_choice
menu kai's utils
item --gap Windows stuff
item option_one ${space} Load PEUtils (efi)
choose custom_choice || goto custom_exit
echo ${cls}
goto ${custom_choice}
goto custom_exit

:option_one
kernel https://boot.netboot.xyz/memdisk raw iso
initrd https://ratted.systems/upload/UCGkekwr.iso
boot || goto custom_exit

:custom_exit
chain utils.ipxe
exit
